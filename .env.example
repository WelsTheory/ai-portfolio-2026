# Copia este archivo como .env y completa los valores
# cp .env.example .env   (nunca subas .env al repo)

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...

# === Modelos (opcional, si cambias del default) ===
CLAUDE_MODEL_RAG=claude-haiku-4-5-20251001
CLAUDE_MODEL_COMPLEX=claude-sonnet-4-6

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_db

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000

# === Streamlit ===
STREAMLIT_PORT=8501
